# Capsule Brain Configuration
# Copy this file to .env and update each section with the values for your environment.

# API Configuration
# Used by the FastAPI application served via uvicorn.
CB_API_HOST=0.0.0.0
CB_API_PORT=8000

# CORS Configuration
# Comma-separated list of allowed origins for browser requests.
ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000

# Authentication
# Shared secrets used by the Capsule Brain admin interfaces.
ADMIN_TOKEN=your_admin_token_here
ADMIN_API_KEY=your_admin_api_key_here

# LLM API Keys (set at least one provider)
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
# COHERE_API_KEY=your_cohere_key_here
# GOOGLE_API_KEY=your-google-api-key-here
# AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here

# Telemetry and Monitoring
# Toggle metrics and tracing exporters.
TELEMETRY_ENABLE=true

# Testing (optional)
# Base URL used by integration tests and scripts.
CB_BASE_URL=http://127.0.0.1:8000

# Legacy CLI Launch Script (optional)
# HOST and PORT are consumed by launch_capsule_brain.py for local development.
HOST=0.0.0.0
PORT=8000

# TLS Reverse Proxy (optional)
# Domain served by the reverse proxy when TLS is enabled.
# CB_DOMAIN=cb.example.com
