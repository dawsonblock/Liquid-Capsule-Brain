# Capsule Brain Configuration
# Copy this file to .env and update with your values

# API Configuration

# Capsule Brain Supreme AGI Environment Configuration

# API Configuration
HOST=0.0.0.0
PORT=8000
       main
CB_API_HOST=0.0.0.0
CB_API_PORT=8000

# CORS Configuration
ALLOW_ORIGINS=http://localhost:3000,http://localhost:8000

# LLM API Keys (set at least one)
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
# COHERE_API_KEY=your_cohere_key_here

# Security
ADMIN_TOKEN=your_admin_token_here

# Telemetry and Monitoring
TELEMETRY_ENABLE=true

# Optional: Custom host/port for launch script
HOST=0.0.0.0
PORT=8000
ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000

# Authentication
ADMIN_TOKEN=your-admin-token-here
ADMIN_API_KEY=your-admin-api-key-here

# LLM Configuration (set one or more)
# OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# GOOGLE_API_KEY=your-google-api-key-here
# AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here

# Monitoring & Telemetry
TELEMETRY_ENABLE=true

# Testing (optional)
CB_BASE_URL=http://127.0.0.1:8000

# TLS Reverse Proxy (optional, for reverse proxy setup)
# CB_DOMAIN=cb.example.com
        main
