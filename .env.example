# Capsule Brain configuration template
# Copy this file to `.env` and adjust each section for your environment.

# -----------------------------------------------------------------------------
# API server (FastAPI served by uvicorn)
# CB_API_HOST is mainly used by deployment manifests while the dev script binds
# directly to 0.0.0.0. Override the values below when exposing Capsule Brain on
# a different interface or port.
# -----------------------------------------------------------------------------
CB_API_HOST=0.0.0.0
CB_API_PORT=8000

# -----------------------------------------------------------------------------
# Cross-Origin Resource Sharing (CORS)
# Comma-separated list of allowed browser origins. No spaces between entries.
# Include both localhost and 127.0.0.1 variants if you develop with either.
# -----------------------------------------------------------------------------
ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# Authentication secrets for admin interfaces (Capsule Brain + overseer)
# Regenerate these secrets before deploying beyond local development.
# -----------------------------------------------------------------------------
ADMIN_TOKEN=your_admin_token_here
ADMIN_API_KEY=your_admin_api_key_here

# -----------------------------------------------------------------------------
# Large language model (LLM) provider API keys — set at least one provider.
# Uncomment additional providers as needed. Leave unused lines commented out so
# `scripts/run_dev.sh` does not export empty variables into your shell.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
# COHERE_API_KEY=your_cohere_key_here
# GOOGLE_API_KEY=your_google_api_key_here
# AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here

# -----------------------------------------------------------------------------
# Telemetry and monitoring exporters
# Set TELEMETRY_ENABLE to "false" to disable emitting telemetry locally.
# -----------------------------------------------------------------------------
TELEMETRY_ENABLE=true

# -----------------------------------------------------------------------------
# Testing helpers
# Used by integration tests and utility scripts when exercising the API.
# -----------------------------------------------------------------------------
CB_BASE_URL=http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# Legacy launcher / CLI compatibility
# The legacy Python entry points still read HOST and PORT directly.
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# -----------------------------------------------------------------------------
# TLS reverse proxy guidance
# Uncomment and set when running behind a TLS-enabled reverse proxy.
# -----------------------------------------------------------------------------
# CB_DOMAIN=cb.example.com
