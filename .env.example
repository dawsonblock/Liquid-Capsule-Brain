# Capsule Brain configuration template
# -----------------------------------------------------------------------------
# Copy this file to `.env` and adjust the values to match your environment.
# `scripts/run_dev.sh` expects the same variable names defined below, so keep
# the keys but feel free to change the values. Avoid checking the populated
# `.env` file into source control.

# =============================================================================
# API server (FastAPI served by uvicorn)
# =============================================================================
# `CB_API_HOST` is primarily consumed by deployment manifests. The development
# launcher binds to `0.0.0.0` regardless, but overriding the defaults here keeps
# the generated `.env` aligned with your deployment topology. `CB_API_PORT` is
# referenced both by uvicorn and by `scripts/run_dev.sh`.
CB_API_HOST=0.0.0.0
CB_API_PORT=8000

# =============================================================================
# Cross-Origin Resource Sharing (CORS)
# =============================================================================
# Provide a comma-separated list of allowed browser origins. Do not include
# spaces between entries. Add both `localhost` and `127.0.0.1` variants when
# developing locally to avoid confusing preflight failures.
ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000

# =============================================================================
# Authentication secrets for admin interfaces (Capsule Brain + overseer)
# =============================================================================
# These values gate administrative access. Generate fresh secrets before
# deploying anywhere other than your local machine and rotate them regularly in
# production.
ADMIN_TOKEN=your_admin_token_here
ADMIN_API_KEY=your_admin_api_key_here

# =============================================================================
# Large language model (LLM) provider API keys
# =============================================================================
# Set at least one provider. Leave unused providers commented out so
# `scripts/run_dev.sh` does not export empty values into your shell. When using
# Azure OpenAI, configure the Azure deployment-specific variables separately.
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
# COHERE_API_KEY=your_cohere_key_here
# GOOGLE_API_KEY=your_google_api_key_here
# AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here

# =============================================================================
# Telemetry and monitoring exporters
# =============================================================================
# Capsule Brain emits OpenTelemetry spans and metrics by default. Flip the flag
# below to `false` if you prefer to disable telemetry while developing locally.
TELEMETRY_ENABLE=true

# =============================================================================
# Testing helpers
# =============================================================================
# Integration tests and smoke scripts use this base URL when making requests to
# the API. Adjust the scheme, host, or port if your deployment differs from the
# FastAPI defaults above.
CB_BASE_URL=http://127.0.0.1:8000

# =============================================================================
# Legacy launcher / CLI compatibility
# =============================================================================
# The legacy Python entry points still read the generic `HOST` and `PORT`
# variables directly. Keep these synchronized with the `CB_API_*` values until
# the CLI is fully migrated.
HOST=0.0.0.0
PORT=8000

# =============================================================================
# TLS reverse proxy guidance
# =============================================================================
# Uncomment this when running Capsule Brain behind a TLS-enabled reverse proxy
# and set it to the externally visible domain name.
# CB_DOMAIN=cb.example.com
