# Dev container for Capsule Brain
FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# System deps (minimal)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential curl git && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt /app/requirements.txt
COPY requirements-dev.txt /app/requirements-dev.txt
RUN pip install --upgrade pip &&     pip install -r /app/requirements.txt &&     pip install -r /app/requirements-dev.txt

# Copy project
COPY . /app

EXPOSE 8000
CMD ["uvicorn", "capsule_brain.api.server:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
